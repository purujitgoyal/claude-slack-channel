{
  "name": "claude-slack-channel",
  "version": "0.7.1",
  "license": "MIT",
  "type": "module",
  "bin": "./server.ts",
  "scripts": {
    "start": "bun server.ts",
    "test": "bun test",
    "test:unit": "bun test --filter '!integration'",
    "test:integration": "INTEGRATION=1 bun test test/integration.test.ts",
    "diagnose": "bun test/diagnose.ts",
    "typecheck": "bun --typecheck server.ts",
    "check": "biome check .",
    "fix": "biome check --fix ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@slack/bolt": "^3.22.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10"
  }
}
